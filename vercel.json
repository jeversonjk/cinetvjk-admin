{
  "buildCommand": "",
  "outputDirectory": "dist/public",
  "installCommand": "echo skip",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://ohjpkvrmbdcqnlcuiwxf.supabase.co/functions/v1/admin-api/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
